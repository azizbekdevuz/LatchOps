# Database (PostgreSQL in production; SQLite for local: file:./latchops.db)
DATABASE_URL=postgresql://user:password@localhost:5432/latchops

# Optional: Anthropic API key for LLM-assisted planning and explanations
ANTHROPIC_API_KEY=

# Optional: Python analysis service (apps/agent)
AGENT_URL=http://localhost:8000

# NextAuth (if using dashboard auth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret
